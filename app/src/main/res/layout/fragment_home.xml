<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:orientation="vertical"
    tools:context=".ui.HomeFragment">

    <!-- Placeholder layout for locking screen-->
    <FrameLayout
        android:id="@+id/lock"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:contentDescription="@string/lock_layout_description" />

    <!-- Top info area: clock/date/battery left, weather right -->
    <LinearLayout
        android:id="@+id/dateTimeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="56dp"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Left block: clock, date, battery -->
        <LinearLayout
            android:id="@+id/clockDateBatteryBlock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextClock
                android:id="@+id/clock"
                style="@style/TextDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:format12Hour="h:mm"
                android:textSize="@dimen/time_size"
                tools:text="02:34" />

            <TextView
                android:id="@+id/date"
                style="@style/TextDefault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:paddingHorizontal="3dp"
                android:textSize="@dimen/date_size"
                tools:text="Sat, 14 Mar 2026" />

            <ProgressBar
                android:id="@+id/batteryProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/home_battery_bar_height"
android:layout_marginTop="12dp"
            android:max="100"
                android:progress="75"
                android:progressDrawable="@drawable/home_battery_progress"
                tools:progress="75" />
        </LinearLayout>

        <!-- Right block: weather widget -->
        <LinearLayout
            android:id="@+id/weatherWidget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:clickable="true"
            android:focusable="true"
            android:gravity="end"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <!-- Primary row: icon + temperature + unit -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/weatherIcon"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/weather"
                    android:src="@drawable/ic_weather_clear_home" />

                <TextView
                    android:id="@+id/weatherTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    tools:text="46°" />

                <TextView
                    android:id="@+id/weatherUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top"
                    android:layout_marginTop="2dp"
                    android:textColor="#AAFFFFFF"
                    android:textSize="10sp"
                    tools:text="c" />
            </LinearLayout>

            <!-- Secondary row: humidity, visibility, AQI -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:contentDescription="@string/humidity"
                    android:src="@drawable/ic_humidity_home" />

                <TextView
                    android:id="@+id/weatherHumidity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    tools:text="37%" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/visibility"
                    android:src="@drawable/ic_visibility_home" />

                <TextView
                    android:id="@+id/weatherVisibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    tools:text="33mi" />

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/aqi"
                    android:src="@drawable/ic_aqi_home" />

                <TextView
                    android:id="@+id/weatherAqi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    tools:text="51" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Screen time-->
    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tvScreenTime"
        style="@style/TextSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="72dp"
        android:gravity="center"
        android:padding="10dp"
        android:textSize="@dimen/date_size"
        android:visibility="gone"
        tools:text="2h 11m"
        tools:visibility="visible" />

    <!-- Home apps viewport -->
    <LinearLayout
        android:id="@+id/homeAppsLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal|center_vertical"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="112dp"
        android:paddingBottom="48dp">

        <FrameLayout
            android:id="@+id/homeAppsViewport"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/black"
            android:clipToPadding="true">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/pinnedAppsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/black"
                android:overScrollMode="never"
                android:scrollbars="none"
                tools:itemCount="7"
                tools:listitem="@layout/item_home_pinned_app" />

            <View
                android:id="@+id/topFadeOverlay"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_pinned_fade_height"
                android:background="@drawable/home_fade_top"
                android:visibility="gone" />

            <View
                android:id="@+id/bottomFadeOverlay"
                android:layout_width="match_parent"
                android:layout_height="@dimen/home_pinned_fade_height"
                android:layout_gravity="bottom"
                android:background="@drawable/home_fade_bottom"
                android:visibility="gone" />
        </FrameLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/firstRunTips"
        style="@style/TextSmall"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="56dp"
        android:text="@string/swipe_up_for_apps"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Set default launcher -->
    <TextView
        android:id="@+id/setDefaultLauncher"
        style="@style/TextMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="56dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="@string/set_as_default_launcher_u"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/cornerActionsOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="20dp"
        android:paddingBottom="44dp">

        <ImageView
            android:id="@+id/phoneCornerAction"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="bottom|start"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/swipe_right_app"
            android:focusable="true"
            android:padding="2dp"
            android:src="@drawable/ic_phone_home"
            android:tint="@android:color/white" />

        <ImageView
            android:id="@+id/cameraCornerAction"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="bottom|end"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:contentDescription="@string/swipe_left_app"
            android:focusable="true"
            android:padding="2dp"
            android:src="@drawable/ic_camera_home"
            android:tint="@android:color/white" />
    </FrameLayout>
</FrameLayout>