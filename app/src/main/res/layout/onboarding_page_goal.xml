<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Step dots -->
    <LinearLayout
        android:id="@+id/stepDots"
        android:layout_width="wrap_content"
        android:layout_height="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginTop="60dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:layout_marginEnd="6dp"
            android:background="#40FFFFFF" />

        <View
            android:layout_width="20dp"
            android:layout_height="4dp"
            android:layout_marginEnd="6dp"
            android:background="#E6FFFFFF" />

        <View
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:layout_marginEnd="6dp"
            android:background="#40FFFFFF" />

        <View
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:background="#40FFFFFF" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="28dp"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:lineSpacingMultiplier="1.1"
        android:text="What's your\nintention?"
        android:textColor="@color/whiteTrans90"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stepDots" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-light"
        android:text="This will show on your home screen as a reminder."
        android:textColor="@color/whiteTrans50"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <EditText
        android:id="@+id/etGoal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="32dp"
        android:background="@drawable/bg_onboarding_option"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:hint="e.g. Be present, not scrolling"
        android:inputType="textCapSentences"
        android:maxLines="2"
        android:paddingHorizontal="20dp"
        android:paddingVertical="18dp"
        android:textColor="@color/whiteTrans90"
        android:textColorHint="@color/whiteTrans50"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

    <TextView
        android:id="@+id/btnGoalContinue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        android:background="@drawable/bg_reflection_done_button"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:letterSpacing="0.08"
        android:minHeight="52dp"
        android:text="CONTINUE"
        android:textColor="@color/whiteTrans90"
        android:textSize="13sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/btnGoalSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:padding="12dp"
        android:text="Skip"
        android:textColor="@color/whiteTrans50"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@id/btnGoalContinue"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
