<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Step dots -->
    <LinearLayout
        android:id="@+id/stepDots"
        android:layout_width="wrap_content"
        android:layout_height="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="60dp">

        <View
            android:id="@+id/dot1"
            android:layout_width="20dp"
            android:layout_height="4dp"
            android:background="#E6FFFFFF"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/dot2"
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:background="#40FFFFFF"
            android:layout_marginEnd="6dp" />

        <View
            android:id="@+id/dot3"
            android:layout_width="6dp"
            android:layout_height="4dp"
            android:background="#40FFFFFF" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="28dp"
        android:fontFamily="sans-serif"
        android:text="Why are you\nhere?"
        android:textColor="@color/whiteTrans90"
        android:textSize="34sp"
        android:textStyle="bold"
        android:gravity="center"
        android:lineSpacingMultiplier="1.1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stepDots" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="28dp"
        android:layout_marginEnd="28dp"
        android:layout_marginTop="8dp"
        android:fontFamily="sans-serif-light"
        android:text="Pick what fits most."
        android:textColor="@color/whiteTrans50"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- Options container — populated programmatically -->
    <LinearLayout
        android:id="@+id/optionsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="28dp"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle" />

    <TextView
        android:id="@+id/btnContinue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="40dp"
        android:alpha="0.35"
        android:background="@drawable/bg_reflection_done_button"
        android:clickable="true"
        android:enabled="false"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:minHeight="52dp"
        android:text="CONTINUE"
        android:textColor="@color/whiteTrans90"
        android:textSize="13sp"
        android:textStyle="bold"
        android:letterSpacing="0.08"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
