<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_reflection_setup_dialog"
    android:elevation="10dp"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <TextView
        android:id="@+id/reflection_dialog_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/reflection_pause_dialog_title"
        android:textColor="@color/whiteTrans90"
        android:textSize="@dimen/text_large" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/reflection_apps_list"
        android:layout_width="match_parent"
        android:layout_height="@dimen/reflection_setup_list_height"
        android:clipToPadding="false"
        android:fadeScrollbars="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarThumbVertical="@color/whiteTrans50"
        android:scrollbars="vertical" />

    <TextView
        android:id="@+id/reflection_dialog_done"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_reflection_done_button"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackground"
        android:gravity="center"
        android:minHeight="48dp"
        android:text="@string/done"
        android:textColor="@color/whiteTrans90"
        android:textSize="@dimen/text_small"
        android:textStyle="bold" />

</LinearLayout>
